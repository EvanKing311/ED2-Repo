      Object {
	$PropName		"MaskObject"
	$ObjectID		35
	$ClassName		"Simulink.Mask"
	Type			"PID Controller"
	Description		"Enter expressions for proportional, integral, and derivative terms.\nP+I/s+Ds"
	Help			"This block implements a PID controller where parameters are entered for the Proportional, Integral and Deriva"
	"tive terms. Unmask this block to see how it works. The derivative term is implemented using a true derivative block."
	Display			"image(imread('bckg.bmp'))\ndisp('PID')"
	Array {
	  Type			  "Simulink.MaskParameter"
	  Dimension		  3
	  Object {
	    $ObjectID		    36
	    Type		    "edit"
	    Name		    "P"
	    Prompt		    "Proportional:"
	    Value		    "27.8"
	    Callback		    "if str2num(get_param(gcb, 'P'))>50\n WARNDLG('Proportional Gain is out of the range [10..50] and i"
	    "s set to maximum value now', 'Setting Value Error')\n set_param(gcb,'P','50'); \nend\nif str2num(get_param(gcb, '"
	    "P'))<10\n WARNDLG('Proportional Gain is out of the range [10..50] and is set to minimum now', 'Setting Value Erro"
	    "r')\n set_param(gcb,'P','10'); \nend"
	  }
	  Object {
	    $ObjectID		    37
	    Type		    "edit"
	    Name		    "I"
	    Prompt		    "Integral:"
	    Value		    "50"
	    Callback		    "if str2num(get_param(gcb, 'I'))>75\n WARNDLG('Integral Gain is out of the range [25..75] and is se"
	    "t to maximum value now', 'Setting Value Error')\n set_param(gcb,'I','75'); \nend\nif str2num(get_param(gcb, 'I'))"
	    "<25\n WARNDLG('Integral Gain is out of the range [25..75] and is set to minimum value now', 'Setting Value Error'"
	    ")\n set_param(gcb,'I','25'); \nend"
	  }
	  Object {
	    $ObjectID		    38
	    Type		    "edit"
	    Name		    "D"
	    Prompt		    "Derivative:"
	    Value		    "3.9"
	    Callback		    "if str2num(get_param(gcb, 'D'))>4\n WARNDLG('Derivative Gain is out of the range [2..6] and is set"
	    " to maximum value now', 'Setting Value Error')\n set_param(gcb,'D','4'); \nend\nif str2num(get_param(gcb, 'D'))<2"
	    "\n WARNDLG('Derivative Gain is out of the range [2..6] and is set to minimum value now', 'Setting Value Error')\n"
	    " set_param(gcb,'D','2'); \nend"
	  }
	  PropName		  "Parameters"
	}
      }
