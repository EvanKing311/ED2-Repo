	Block {
	  BlockType		  SubSystem
	  Name			  "PID Controller\n with D part filter"
	  SID			  "106"
	  Ports			  [1, 1]
	  Position		  [250, 79, 295, 121]
	  ZOrder		  -8
	  AncestorBlock		  "simulink_extras/Additional\nLinear/PID Controller"
	  LibraryVersion	  "*"
	  FontName		  "Arial"
	  FontSize		  12
	  FontWeight		  "bold"
	  RequestExecContextInheritance	off
	  Variant		  off
	  Object {
	    $PropName		    "MaskObject"
	    $ObjectID		    36
	    $ClassName		    "Simulink.Mask"
	    Type		    "PID Controller"
	    Description		    "Enter expressions for proportional, integral, and derivative terms.\nP+I/s+Ds"
	    Help		    "This block implements a PID controller where parameters are entered for the Proportional, Integral and"
	    " Derivative terms. Unmask this block to see how it works. The derivative term is implemented using a true derivat"
	    "ive block."
	    Display		    "image(imread('bckg.bmp'))\ndisp('PID')"
	    Array {
	      Type		      "Simulink.MaskParameter"
	      Dimension		      3
	      Object {
		$ObjectID		37
		Type			"edit"
		Name			"P"
		Prompt			"Proportional:"
		Value			"7"
		Callback		"if str2num(get_param(gcb, 'P'))>10\n WARNDLG('Proportional Gain is out of the range [4..10] and is set to"
		" maximum value now', 'Setting Value Error')\n set_param(gcb,'P','10'); \nend\nif str2num(get_param(gcb, 'P'))<4\n WA"
		"RNDLG('Proportional Gain is out of the range [4..10] and is set to minimum now', 'Setting Value Error')\n set_param("
		"gcb,'P','4'); \nend"
	      }
	      Object {
		$ObjectID		38
		Type			"edit"
		Name			"I"
		Prompt			"Integral:"
		Value			"0.5"
		Callback		"if str2num(get_param(gcb, 'I'))>0.75\n WARNDLG('Integral Gain is out of the range [0.25 .. 0.75] and is s"
		"et to maximum value now', 'Setting Value Error')\n set_param(gcb,'I','0.75'); \nend\nif str2num(get_param(gcb, 'I'))"
		"<0.25\n WARNDLG('Integral Gain is out of the range [0.25 .. 0.75] and is set to minimum now', 'Setting Value Error')"
		"\n set_param(gcb,'I','0.25'); \nend"
	      }
	      Object {
		$ObjectID		39
		Type			"edit"
		Name			"D"
		Prompt			"Derivative:"
		Value			"4"
		Callback		"if str2num(get_param(gcb, 'D'))>6\n WARNDLG('Derivative Gain is out of the range [2..6] and is set to max"
		"imum value now', 'Setting Value Error')\n set_param(gcb,'D','6'); \nend\nif str2num(get_param(gcb, 'D'))<2\n WARNDLG"
		"('Derivative Gain is out of the range [2..6] and is set to minimum now', 'Setting Value Error')\n set_param(gcb,'D',"
		"'2'); \nend"
	      }
	      PropName		      "Parameters"
	    }
	  }
